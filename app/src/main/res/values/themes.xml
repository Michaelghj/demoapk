<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AntiAddiction" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent</item>
        <item name="colorOnSecondary">@color/white</item>
    </style>
    
    <style name="Theme.AntiAddiction.Fullscreen" parent="Theme.AntiAddiction">
        <item name="android:actionBarStyle">@style/Widget.Theme.AntiAddiction.ActionBar.Fullscreen</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
    
    <style name="Widget.Theme.AntiAddiction.ActionBar.Fullscreen" parent="Widget.AppCompat.ActionBar">
        <item name="android:background">@color/black</item>
    </style>
</resources>
